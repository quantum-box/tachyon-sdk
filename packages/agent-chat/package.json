{
	"name": "@anthropic-ja/agent-chat",
	"version": "0.2.2",
	"description": "React component library for Tachyon agent chat, plus agent skill definitions",
	"type": "module",
	"main": "./dist/index.umd.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.umd.cjs"
		},
		"./skills/image-gen.json": "./skills/image-gen.json"
	},
	"files": [
		"dist",
		"skills",
		"CHANGELOG.md"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/anthropic-ja/tachyon-sdk.git",
		"directory": "packages/agent-chat"
	},
	"license": "MIT",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"lint": "biome lint ./src",
		"format": "biome format ./src",
		"format:write": "biome format --write ./src",
		"ts": "tsc --noEmit --incremental",
		"ts:watch": "tsc --noEmit --incremental --watch"
	},
	"peerDependencies": {
		"react": "18 - 19",
		"react-dom": "18 - 19"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9",
		"@types/react": "^18.3.11",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.3",
		"typescript": "~5.6.2",
		"vite": "^5.4.9",
		"vite-plugin-dts": "^4.3.0"
	}
}
