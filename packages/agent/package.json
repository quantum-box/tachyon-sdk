{
	"name": "@quantumbox/agent",
	"version": "0.1.0",
	"description": "Tachyon Agent SDK — TypeScript client for the Tachyon Agent API",
	"author": "Quantum Box <hello@quantum-box.com>",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"type": "module",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"import": "./src/index.ts",
			"types": "./src/index.ts"
		}
	},
	"files": [
		"src"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/quantum-box/tachyon-sdk.git",
		"directory": "packages/agent"
	},
	"license": "MIT",
	"scripts": {
		"build": "vite build",
		"lint": "biome lint ./src",
		"format": "biome format ./src",
		"format:write": "biome format --write ./src",
		"ts": "tsc --noEmit --incremental",
		"ts:watch": "tsc --noEmit --incremental --watch"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9",
		"typescript": "~5.6.2",
		"vite": "^5.4.9",
		"vite-plugin-dts": "^4.3.0"
	}
}
