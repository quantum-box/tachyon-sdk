{
  "name": "@quantumbox/tachyon-agent",
  "version": "0.2.0",
  "description": "Lightweight TypeScript SDK for Tachyon Agent API, plus agent skill definitions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./skills/image-gen.json": "./skills/image-gen.json"
  },
  "files": ["dist", "skills", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "~5.6.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quantum-box/tachyon-sdk.git",
    "directory": "packages/agent"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["tachyon", "agent", "ai", "sdk"]
}
